        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{related_slug}" ]
    ] .


###############################################################################
#  PHILOSOPHY VALUES — ae-ont:Value with skos:scopeNote "philosophy"
###############################################################################

<#PhilosophyValueMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_philosophy_values.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/value/{value_slug}" ;
        rr:class ae-ont:Value
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "value" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "value" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:scopeNote ;
        rr:objectMap [ rr:constant "philosophy" ; rr:language "en" ]
    ] .

