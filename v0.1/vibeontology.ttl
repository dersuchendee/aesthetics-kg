@prefix : <http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vibe: <http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/> .
@base <http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#> .

<http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal> rdf:type owl:Ontology .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/associatedSubculture
vibe:associatedSubculture rdf:type owl:ObjectProperty ;
                          rdfs:domain vibe:Aesthetic ;
                          rdfs:range vibe:Subculture .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/associationDimension
vibe:associationDimension rdf:type owl:ObjectProperty ;
                          rdfs:domain vibe:RepresentativeAssociation ;
                          rdfs:range owl:Thing ;
                          rdfs:comment "Classifies the kind of association. Expected values are the named individuals: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/atTime
vibe:atTime rdf:type owl:ObjectProperty ;
            rdfs:domain vibe:TimeIndexedRole ;
            rdfs:range vibe:TimeInterval .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/coinedBy
vibe:coinedBy rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Aesthetic ;
              rdfs:range vibe:Agent .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/follows
vibe:follows rdf:type owl:ObjectProperty ;
             owl:inverseOf vibe:precedes ;
             rdf:type owl:TransitiveProperty ;
             rdfs:domain vibe:Aesthetic ;
             rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/forAesthetic
vibe:forAesthetic rdf:type owl:ObjectProperty ;
                  rdfs:domain vibe:RepresentativeAssociation ;
                  rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasColorPalette
vibe:hasColorPalette rdf:type owl:ObjectProperty ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:ColorPalette .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasCreator
vibe:hasCreator rdf:type owl:ObjectProperty ;
                rdfs:domain vibe:Aesthetic ;
                rdfs:range vibe:Agent .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasIconicFigure
vibe:hasIconicFigure rdf:type owl:ObjectProperty ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:Agent .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasLocation
vibe:hasLocation rdf:type owl:ObjectProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range vibe:Location .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasLocationOfOrigin
vibe:hasLocationOfOrigin rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf vibe:hasLocation ;
                         rdfs:domain vibe:Aesthetic ;
                         rdfs:range vibe:Location .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasMember
vibe:hasMember rdf:type owl:ObjectProperty ;
               owl:inverseOf vibe:isMemberOf ;
               rdfs:domain vibe:Collection ;
               rdfs:range owl:Thing .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasMotif
vibe:hasMotif rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Artwork ;
              rdfs:range vibe:Motif .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasOriginPeriod
vibe:hasOriginPeriod rdf:type owl:ObjectProperty ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:TimeInterval .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasPeriodDefinition
vibe:hasPeriodDefinition rdf:type owl:ObjectProperty ;
                         rdfs:domain owl:Thing ;
                         rdfs:range vibe:PeriodDefinition .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasPlatform
vibe:hasPlatform rdf:type owl:ObjectProperty ;
                 rdfs:domain vibe:Aesthetic ;
                 rdfs:range vibe:Platform .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasPrimaryPlatform
vibe:hasPrimaryPlatform rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf vibe:hasPlatform ;
                        rdfs:domain vibe:Aesthetic ;
                        rdfs:range vibe:Platform .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasRelatedBrand
vibe:hasRelatedBrand rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf vibe:relatedTo ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:Brand .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasRelatedWork
vibe:hasRelatedWork rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf vibe:relatedTo ;
                    rdfs:domain vibe:Aesthetic ;
                    rdfs:range vibe:Artwork .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasSubgenre
vibe:hasSubgenre rdf:type owl:ObjectProperty ;
                 owl:equivalentProperty <http://www.w3.org/2004/02/skos/core#narrower> ;
                 rdfs:subPropertyOf vibe:relatedTo ;
                 owl:inverseOf vibe:isSubgenreOf ;
                 rdfs:domain vibe:Aesthetic ;
                 rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasTheme
vibe:hasTheme rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Artwork ;
              rdfs:range vibe:Theme .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/hasValue
vibe:hasValue rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Aesthetic ;
              rdfs:range vibe:Value .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/influenced
vibe:influenced rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf vibe:relatedTo ;
                owl:inverseOf vibe:influencedBy ;
                rdfs:domain vibe:Aesthetic ;
                rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/influencedBy
vibe:influencedBy rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf vibe:relatedTo ;
                  rdfs:domain vibe:Aesthetic ;
                  rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/isMemberOf
vibe:isMemberOf rdf:type owl:ObjectProperty ;
                rdfs:domain owl:Thing ;
                rdfs:range vibe:Collection .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/isRoleInTimeOf
vibe:isRoleInTimeOf rdf:type owl:ObjectProperty ;
                    rdfs:domain vibe:TimeIndexedRole ;
                    rdfs:range vibe:Platform .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/isSubgenreOf
vibe:isSubgenreOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf vibe:relatedTo ;
                  rdfs:domain vibe:Aesthetic ;
                  rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/overlapsWith
vibe:overlapsWith rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf vibe:relatedTo ;
                  rdf:type owl:SymmetricProperty ;
                  rdfs:domain vibe:Aesthetic ;
                  rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/precedes
vibe:precedes rdf:type owl:ObjectProperty ,
                       owl:TransitiveProperty ;
              rdfs:domain vibe:Aesthetic ;
              rdfs:range vibe:Aesthetic .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/relatedTo
vibe:relatedTo rdf:type owl:ObjectProperty ,
                        owl:SymmetricProperty ;
               rdfs:domain vibe:Aesthetic ;
               rdfs:range owl:Thing .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/source
vibe:source rdf:type owl:ObjectProperty ;
            rdfs:domain vibe:PeriodDefinition ;
            rdfs:range vibe:Agent .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/timeInterval
vibe:timeInterval rdf:type owl:ObjectProperty ;
                  rdfs:domain vibe:PeriodDefinition ;
                  rdfs:range vibe:TimeInterval .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/withEntity
vibe:withEntity rdf:type owl:ObjectProperty ;
                rdfs:domain vibe:RepresentativeAssociation ;
                rdfs:range owl:Thing .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/withRole
vibe:withRole rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:TimeIndexedRole ;
              rdfs:range vibe:Role .


###  http://www.w3.org/2004/02/skos/core#broader
<http://www.w3.org/2004/02/skos/core#broader> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#narrower
<http://www.w3.org/2004/02/skos/core#narrower> rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/URL
vibe:URL rdf:type owl:DatatypeProperty ;
         rdfs:domain vibe:Aesthetic ;
         rdfs:range xsd:anyURI ;
         rdfs:comment "The wiki URL (aesthetic)" .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/alternateName
vibe:alternateName rdf:type owl:DatatypeProperty ;
                   owl:equivalentProperty <http://www.w3.org/2004/02/skos/core#altLabel> ;
                   rdfs:domain vibe:Aesthetic ;
                   rdfs:range xsd:string .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/approximateLabel
vibe:approximateLabel rdf:type owl:DatatypeProperty ;
                      rdfs:domain vibe:TimeInterval ;
                      rdfs:range xsd:string .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/endYear
vibe:endYear rdf:type owl:DatatypeProperty ;
             rdfs:domain vibe:TimeInterval ;
             rdfs:range xsd:gYear .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/name
vibe:name rdf:type owl:DatatypeProperty ;
          owl:equivalentProperty <http://www.w3.org/2004/02/skos/core#prefLabel> ;
          rdfs:domain vibe:Aesthetic ;
          rdfs:range xsd:string .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/representativenessType
vibe:representativenessType rdf:type owl:DatatypeProperty ;
                            rdfs:domain vibe:RepresentativeAssociation ;
                            rdfs:range xsd:string .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/startYear
vibe:startYear rdf:type owl:DatatypeProperty ;
               rdfs:domain vibe:TimeInterval ;
               rdfs:range xsd:gYear .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:DatatypeProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Aesthetic
vibe:Aesthetic rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty vibe:hasMember ;
                                 owl:minCardinality "1"^^xsd:nonNegativeInteger
                               ] ;
               rdfs:comment """An Aesthetic is a culturally emergent, open-ended category that groups a collection of heterogeneous elements (e.g., images, colors, objects, sounds, texts) perceived as coherently expressing a recognizable style, affect, or orientation. It is not defined by necessary and sufficient conditions, but by shared associations and family resemblances established by a community.
Example: Frutiger Aero groups glossy textures, bright gradients, nature imagery, and optimistic “future” cues into a recognizable early-2000s style."""@en ;
               rdfs:label "Aesthetic"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Agent
vibe:Agent rdf:type owl:Class ;
           rdfs:label "Agent"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/ArchitecturalWork
vibe:ArchitecturalWork rdf:type owl:Class ;
                       rdfs:subClassOf vibe:Artwork ;
                       rdfs:label "Architectural Work"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/ArtistRole
vibe:ArtistRole rdf:type owl:Class ;
                rdfs:subClassOf vibe:Role ;
                rdfs:label "Artist Role"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Artwork
vibe:Artwork rdf:type owl:Class ;
             rdfs:comment "An Artwork is a creative artifact produced within any expressive medium, including visual (images, paintings, sculpture, architecture, film, videogames), auditory (music), textual (literature), or embodied/industrial forms (fashion). It is treated as a generic work entity independent of medium-specific taxonomies."@en ;
             rdfs:label "Artwork"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Brand
vibe:Brand rdf:type owl:Class ;
           rdfs:comment "A Brand is an identifiable commercial or institutional entity characterized by a name, identity, and set of associated meanings, values, and design practices, which can produce or influence artifacts, styles, and aesthetic associations."@en ;
           rdfs:label "Brand"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/City
vibe:City rdf:type owl:Class ;
          rdfs:subClassOf vibe:Location ;
          rdfs:label "City"@en .
<<<<<<< HEAD
          rdfs:label "市"@ja .
=======
          rdfs:label "Stad"@nl .
>>>>>>> main


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Collection
vibe:Collection rdf:type owl:Class ;
                rdfs:comment "A Collection is a set of entities grouped together, either explicitly or implicitly, based on perceived coherence, curation, or shared associations. Collections function as the primary means through which an Aesthetic is expressed and recognized, without requiring fixed or exhaustive membership."@en ;
                rdfs:label "Collection"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Color
vibe:Color rdf:type owl:Class ;
           rdfs:label "Color"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/ColorPalette
vibe:ColorPalette rdf:type owl:Class ;
                  rdfs:comment "A ColorPalette is a structured set of colors associated through recurrent co-occurrence, design conventions, or perceptual harmony, often contributing to the visual identity of an aesthetic."@en ;
                  rdfs:label "Color Palette"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Country
vibe:Country rdf:type owl:Class ;
             rdfs:subClassOf vibe:Location ;
             rdfs:label "Country"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/DigitalPlace
vibe:DigitalPlace rdf:type owl:Class ;
                  rdfs:subClassOf vibe:Location ;
                  rdfs:comment "A DigitalPlace is a subclass of Location representing a virtual environment where interactions, content creation, or community practices occur (e.g., forums, websites, social networks)."@en ;
                  rdfs:label "DigitalPlace"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Fashion
vibe:Fashion rdf:type owl:Class ;
             rdfs:comment "Fashion is a domain of embodied and material expression involving clothing, styling, and adornment practices, through which cultural meanings, identities, and aesthetic orientations are communicated."@en ;
             rdfs:label "Fashion"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Group
vibe:Group rdf:type owl:Class ;
           rdfs:subClassOf vibe:Agent ;
           rdfs:label "Group"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/IconicFigure
vibe:IconicFigure rdf:type owl:Class ;
                  rdfs:subClassOf vibe:Role ;
                  rdfs:label "Iconic Figure"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Image
vibe:Image rdf:type owl:Class ;
           rdfs:subClassOf vibe:Artwork ;
           rdfs:label "Image"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/InteriorDesign
vibe:InteriorDesign rdf:type owl:Class ;
                    rdfs:subClassOf vibe:ArchitecturalWork ;
                    rdfs:label "Interior Design"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/LiteraryWork
vibe:LiteraryWork rdf:type owl:Class ;
                  rdfs:subClassOf vibe:Artwork ;
                  rdfs:label "Literary Work"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Location
vibe:Location rdf:type owl:Class ;
              rdfs:label "Location"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Motif
vibe:Motif rdf:type owl:Class ;
           rdfs:comment """A Motif is a recurrent and recognizable element (visual, conceptual, or stylistic) that contributes to the identity of an aesthetic through repeated association.
Example: In Frutiger Aero, motifs include skeuomorphism, glossy textures, bubbles, nature imagery, and Frutiger-type fonts."""@en ;
           rdfs:label "Motif"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/MusicWork
vibe:MusicWork rdf:type owl:Class ;
               rdfs:subClassOf vibe:Artwork ;
               rdfs:label "Music Work"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Painting
vibe:Painting rdf:type owl:Class ;
              rdfs:subClassOf vibe:Artwork ;
              rdfs:label "Painting"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/PeriodDefinition
vibe:PeriodDefinition rdf:type owl:Class ;
                      rdfs:subClassOf [ rdf:type owl:Restriction ;
                                        owl:onProperty vibe:timeInterval ;
                                        owl:minCardinality "1"^^xsd:nonNegativeInteger
                                      ] ;
                      rdfs:comment "A PeriodDefinition is a temporally bounded but potentially imprecise interval used to situate entities or phenomena in time, allowing for vague or overlapping boundaries, in alignment with models such as PeriodO."@en ;
                      rdfs:label "Period Definition"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Person
vibe:Person rdf:type owl:Class ;
            rdfs:subClassOf vibe:Agent ;
            owl:disjointWith vibe:Platform ,
                             vibe:TimeInterval ;
            rdfs:label "Person"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Platform
vibe:Platform rdf:type owl:Class ;
              rdfs:comment "A Platform is a socio-technical system that enables and constrains interaction, content production, and dissemination, while exerting agency through its design, governance, and algorithmic mechanisms, thereby shaping the emergence and visibility of aesthetics."@en ;
              rdfs:label "Platform"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/PrimaryRole
vibe:PrimaryRole rdf:type owl:Class ;
                 rdfs:subClassOf vibe:Role ;
                 rdfs:label "Primary Role"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/RepresentativeAssociation
vibe:RepresentativeAssociation rdf:type owl:Class ;
                               rdfs:comment "A RepresentativeAssociation is a reified relation linking an Aesthetic to an entity that is considered representative of it. Such associations encode the mechanisms through which an aesthetic is recognized and constructed, and may be qualified by temporal scope, degree of representativeness, or role (e.g., primary)."@en ;
                               rdfs:label "Representative Association"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Role
vibe:Role rdf:type owl:Class ;
          rdfs:label "Role"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Subculture
vibe:Subculture rdf:type owl:Class ;
                rdfs:comment "A Subculture is a socially situated group or network characterized by shared practices, values, and symbolic systems that differentiate it from broader cultural contexts, often contributing to the emergence and stabilization of specific aesthetics."@en ;
                rdfs:label "Subculture"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Theme
vibe:Theme rdf:type owl:Class ;
           rdfs:comment """A Theme is an abstract conceptual orientation or narrative underlying an aesthetic, capturing its dominant meanings, affective tone, or worldview.
Example: A theme of Frutiger Aero can be described as an optimistic, clean, and nature-integrated vision of the near future."""@en ;
           rdfs:label "Theme"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/TimeIndexedRole
vibe:TimeIndexedRole rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty vibe:atTime ;
                                       owl:minCardinality "1"^^xsd:nonNegativeInteger
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty vibe:forAesthetic ;
                                       owl:minCardinality "1"^^xsd:nonNegativeInteger
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty vibe:withRole ;
                                       owl:minCardinality "1"^^xsd:nonNegativeInteger
                                     ] ;
                     rdfs:comment "A TimeIndexedRole is a contextual role assigned to an entity within a relation that is explicitly bound to a temporal interval, allowing the same entity to hold different roles at different times."@en ;
                     rdfs:label "Time Indexed Role"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/TimeInterval
vibe:TimeInterval rdf:type owl:Class ;
                  rdfs:comment "A TimeInterval is a temporal extent with a start and/or end that may be precisely defined or approximate, used to qualify the temporal validity of entities, roles, or associations."@en ;
                  rdfs:label "Time Interval"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Value
vibe:Value rdf:type owl:Class ;
           rdfs:comment """A Value is an abstract principle, an affective/axiological orientation, or evaluative dimension (ethical, cultural, aesthetic, or ideological) associated with entities or aesthetics. Values are not limited to moral judgments but include broader attitudinal or conceptual stances.
For example, Frutiger Aero is associated with optimism, cleanliness, techno-natural harmony."""@en ;
           rdfs:label "Value"@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal/Video
vibe:Video rdf:type owl:Class ;
           rdfs:subClassOf vibe:Artwork ;
           rdfs:label "Video"@en .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


