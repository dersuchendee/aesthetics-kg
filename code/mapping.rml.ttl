    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "coined_by" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate owl:sameAs ;
        rr:objectMap [ rml:reference "wikidata_uri" ; rr:termType rr:IRI ]
    ] .

<#PersonCoinedTypeMap>
    rml:logicalSource [
        rml:source              "exploded/split/coined_person.csv" ;
