###############################################################################
#  5. AGENTS — Creators (Person / Group / unknown Agent)
#     All use akg:agent/ namespace so typing maps merge onto same node.
###############################################################################

<#AgentCreatorMap>
    rml:logicalSource [
        rml:source              "exploded/split/creators_all.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/agent/{creator_slug}" ;
        rr:class ae-ont:Agent
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "creator" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "creator" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate owl:sameAs ;
        rr:objectMap [ rml:reference "wikidata_uri" ; rr:termType rr:IRI ]
    ] .

<#PersonCreatorTypeMap>
    rml:logicalSource [
        rml:source              "exploded/split/creators_person.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/agent/{creator_slug}" ;
        rr:class ae-ont:Person
    ] .

<#GroupCreatorTypeMap>
    rml:logicalSource [
        rml:source              "exploded/split/creators_group.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/agent/{creator_slug}" ;
        rr:class ae-ont:Group
    ] .

<#AestheticCreatorLinkMap>
    rml:logicalSource [
        rml:source              "exploded/split/creators_all.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:hasCreator ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/agent/{creator_slug}" ]
    ] .


