    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/agent/{coined_by_slug}" ;
        rr:class ae-ont:Group
    ] .

<#AestheticCoinedByLinkMap>
    rml:logicalSource [
        rml:source              "exploded/split/coined_all.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:coinedBy ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/agent/{coined_by_slug}" ]
    ] .


###############################################################################
#  7. ICONIC FIGURES — via RepresentativeAssociation (iconicFigureDimension)
###############################################################################

<#FigureMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_figures.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/agent/{figure_slug}" ;
        rr:class ae-ont:Agent
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "figure" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "figure" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate owl:sameAs ;
        rr:objectMap [ rml:reference "wikidata_uri" ; rr:termType rr:IRI ]
    ] .

<#FigureAssocMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_figures.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/assoc/figure/{slug}-{figure_slug}" ;
        rr:class ae-ont:RepresentativeAssociation
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [
            rr:template "{name} — iconic figure — {figure}" ;
            rr:language "en"
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:comment ;
        rr:objectMap [
            rr:constant "Representative association linking an aesthetic to one of its iconic figures."@en
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:forAesthetic ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:withEntity ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/agent/{figure_slug}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:associationDimension ;
        rr:objectMap [ rr:constant ae-ont:iconicFigureDimension ]
    ] .

<#AestheticFigureLinkMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_figures.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:hasIconicFigure ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/agent/{figure_slug}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:hasMember ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/agent/{figure_slug}" ]
    ] .


