###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#associatedSubculture
:associatedSubculture rdf:type owl:ObjectProperty ;
                      rdfs:domain :Aesthetic ;
                      rdfs:range :Subculture .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#associationDimension
:associationDimension rdf:type owl:ObjectProperty ;
                      rdfs:domain :RepresentativeAssociation ;
                      rdfs:range owl:Thing ;
                      rdfs:comment "Classifies the kind of association. Expected values are the named individuals: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."@en .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#atTime
:atTime rdf:type owl:ObjectProperty ;
