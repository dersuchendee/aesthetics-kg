###############################################################################
#  AestheticsKG — RML Mapping
#  Base IRI : https://w3id.org/aesthetics-kg/
#  Ontology : https://w3id.org/aesthetics-kg/ontology/
#
#  Run from aestheticswork/ with:
#      python3 run_rml.py
#
#  Prerequisites — add to your ontology before running:
#    ae-ont:foodDimension       rdf:type owl:NamedIndividual
#    ae-ont:hasAssociatedActivity  rdf:type owl:ObjectProperty ;
#                               rdfs:domain ae-ont:Aesthetic ;
#                               rdfs:range  ae-ont:Activity
###############################################################################

@prefix rml:  <http://semweb.mmlab.be/ns/rml#> .
@prefix rr:   <http://www.w3.org/ns/r2rml#> .
@prefix ql:   <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix ae-ont:   <https://w3id.org/aesthetics-kg/ontology/> .
@prefix ae-kg:    <https://w3id.org/aesthetics-kg/> .
@prefix vibe-ont: <https://w3id.org/vibe-ontology/> .
@prefix vibe:     <https://w3id.org/vibe-ontology/> .


###############################################################################
#  1. AESTHETICS — core identity
###############################################################################

<#AestheticMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetics.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}" ;
        rr:class ae-ont:Aesthetic, ae-ont:Collection, skos:Concept
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:name ;
        rr:objectMap [ rml:reference "name" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "name" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "name" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:URL ;
        rr:objectMap [ rml:reference "url" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:definition ;
        rr:objectMap [ rml:reference "intro_text" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:scopeNote ;
        rr:objectMap [ rml:reference "text_visuals" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate owl:sameAs ;
        rr:objectMap [ rml:reference "wikidata_uri" ; rr:termType rr:IRI ]
    ] .


###############################################################################
#  2. ALTERNATE NAMES
###############################################################################

<#AltNameMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_altnames.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:alternateName ;
        rr:objectMap [ rml:reference "altname" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:altLabel ;
        rr:objectMap [ rml:reference "altname" ; rr:language "en" ]
    ] .


###############################################################################
#  3. TEMPORAL — decade → TimeInterval
###############################################################################

<#TimeIntervalMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_decades.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/period/{label_slug}" ;
        rr:class ae-ont:TimeInterval
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "label" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:approximateLabel ;
        rr:objectMap [ rml:reference "label" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:startYear ;
        rr:objectMap [ rml:reference "start_year" ; rr:datatype xsd:gYear ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:endYear ;
        rr:objectMap [ rml:reference "end_year" ; rr:datatype xsd:gYear ]
    ] .

<#AestheticDecadeLinkMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_decades.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:hasOriginPeriod ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/period/{label_slug}" ]
    ] .


