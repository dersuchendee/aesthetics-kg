@prefix : <https://w3id.org/vibe-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vibe: <https://w3id.org/vibe-ontology/> .
@base <https://w3id.org/vibe-ontology#> .

<https://w3id.org/vibe-ontology> rdf:type owl:Ontology ;
                                  rdfs:comment "Ontologia per modellare le estetiche come categorie emergenti basate su collezioni e associazioni rappresentative."@it ,
                                               "Ontology for modelling aesthetics as emergent, collection-based categories grounded in representative associations."@en ;
                                  rdfs:label "Ontologia Vibe"@it ,
                                             "Vibe Ontology"@en .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#broader
<http://www.w3.org/2004/02/skos/core#broader> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#narrower
<http://www.w3.org/2004/02/skos/core#narrower> rdf:type owl:ObjectProperty ;
                                               owl:equivalentProperty vibe:hasSubgenre .


###  https://w3id.org/vibe-ontology/associatedSubculture
vibe:associatedSubculture rdf:type owl:ObjectProperty ;
                          rdfs:domain vibe:Aesthetic ;
                          rdfs:range vibe:Subculture ;
                          rdfs:comment "Collega un'Estetica a una Sottocultura che le è socialmente associata o ha contribuito alla sua emergenza e stabilizzazione."@it ,
                                       "Links an Aesthetic to a Subculture that is socially associated with it or contributed to its emergence and stabilization."@en ;
                          rdfs:label "associated subculture"@en ,
                                     "sottocultura associata"@it .


###  https://w3id.org/vibe-ontology/associationDimension
vibe:associationDimension rdf:type owl:ObjectProperty ;
                          rdfs:domain vibe:RepresentativeAssociation ;
                          rdfs:range owl:Thing ;
                          rdfs:comment "Classifica il tipo di associazione codificata da una RepresentativeAssociation. I valori attesi sono gli individui: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."@it ,
                                       "Classifies the kind of association. Expected values are the named individuals: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."@en ;
                          rdfs:label "association dimension"@en ,
                                     "dimensione dell’associazione"@it .


###  https://w3id.org/vibe-ontology/atTime
vibe:atTime rdf:type owl:ObjectProperty ;
            rdfs:domain vibe:TimeIndexedRole ;
            rdfs:range vibe:TimeInterval ;
            rdfs:comment "Specifica l'intervallo temporale durante il quale un TimeIndexedRole è valido."@it ,
                         "Specifies the temporal interval during which a TimeIndexedRole is valid."@en ;
            rdfs:label "al tempo"@it ,
                       "at time"@en .


###  https://w3id.org/vibe-ontology/coinedBy
vibe:coinedBy rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Aesthetic ;
              rdfs:range vibe:Agent ;
              rdfs:comment "Collega un'Estetica all'Agente che l'ha coniata o che vi ha dato il nome per la prima volta."@it ,
                           "Relates an Aesthetic to the Agent who coined or first named it."@en ;
              rdfs:label "coined by"@en ,
                         "coniato da"@it .


###  https://w3id.org/vibe-ontology/follows
vibe:follows rdf:type owl:ObjectProperty ;
             owl:inverseOf vibe:precedes ;
             rdf:type owl:TransitiveProperty ;
             rdfs:domain vibe:Aesthetic ;
             rdfs:range vibe:Aesthetic ;
             rdfs:comment "Indica che un'Estetica segue temporalmente o stilisticamente un'altra. Questa proprietà è transitiva."@it ,
                          "Indicates that one Aesthetic temporally or stylistically follows another. This property is transitive."@en ;
             rdfs:label "follows"@en ,
                        "segue"@it .


###  https://w3id.org/vibe-ontology/forAesthetic
vibe:forAesthetic rdf:type owl:ObjectProperty ;
                  rdfs:domain vibe:RepresentativeAssociation ;
                  rdfs:range vibe:Aesthetic ;
                  rdfs:comment "Collega una AssociazioneRappresentativa all'Estetica che essa qualifica."@it ,
                               "Links a RepresentativeAssociation to the Aesthetic it qualifies."@en ;
                  rdfs:label "for aesthetic"@en ,
                             "per estetica"@it .


###  https://w3id.org/vibe-ontology/hasColorPalette
vibe:hasColorPalette rdf:type owl:ObjectProperty ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:ColorPalette ;
                     rdfs:comment "Associates an Aesthetic with a characteristic ColorPalette that contributes to its visual identity."@en ,
                                  "Associa un'Estetica a una palette di colori caratteristica che contribuisce alla sua identità visiva." ;
                     rdfs:label "ha palette di colori"@it ,
                                "has color palette"@en .


###  https://w3id.org/vibe-ontology/hasCreator
vibe:hasCreator rdf:type owl:ObjectProperty ;
                rdfs:domain vibe:Aesthetic ;
                rdfs:range vibe:Agent ;
                rdfs:comment "Collega un'Estetica all'Agente che l'ha creata o a cui essa deve la propria origine."@it ,
                             "Relates an Aesthetic to the Agent who created or gave rise to it."@en ;
                rdfs:label "ha creatore"@it ,
                           "has creator"@en .


###  https://w3id.org/vibe-ontology/hasIconicFigure
vibe:hasIconicFigure rdf:type owl:ObjectProperty ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:Agent ;
                     rdfs:comment "Associa un'Estetica a un Agente considerato suo rappresentante emblematico."@it ,
                                  "Associates an Aesthetic with an Agent who is considered an emblematic or iconic representative of it."@en ;
                     rdfs:label "ha figura iconica"@it ,
                                "has iconic figure"@en .


###  https://w3id.org/vibe-ontology/hasLocation
vibe:hasLocation rdf:type owl:ObjectProperty ;
                 rdfs:domain owl:Thing ;
                 rdfs:range vibe:Location ;
                 rdfs:comment "Associa qualsiasi entità a una collocazione spaziale, fisica o digitale."@it ,
                              "Associates any entity with a physical or digital spatial location."@en ;
                 rdfs:label "ha luogo"@it ,
                            "has location"@en .


###  https://w3id.org/vibe-ontology/hasLocationOfOrigin
vibe:hasLocationOfOrigin rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf vibe:hasLocation ;
                         rdfs:domain vibe:Aesthetic ;
                         rdfs:range vibe:Location ;
                         rdfs:comment "Specifica la collocazione geografica o digitale in cui un'Estetica ha avuto origine."@it ,
                                      "Specifies the geographic or digital location where an Aesthetic first originated."@en ;
                         rdfs:label "ha luogo di origine"@it ,
                                    "has location of origin"@en .


###  https://w3id.org/vibe-ontology/hasMember
vibe:hasMember rdf:type owl:ObjectProperty ;
               owl:inverseOf vibe:isMemberOf ;
               rdfs:domain vibe:Collection ;
               rdfs:range owl:Thing ;
               rdfs:comment "Collega una Collezione a una delle entità che la costituiscono. L'appartenenza non implica esaustività né necessità."@it ,
                            "Relates a Collection to one of its constituent entities. Membership does not imply exhaustiveness or strict necessity."@en ;
               rdfs:label "ha membro"@it ,
                          "has member"@en .


###  https://w3id.org/vibe-ontology/hasMotif
vibe:hasMotif rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Artwork ;
              rdfs:range vibe:Motif ;
              rdfs:comment "Associa un'Opera d'arte a un motivo ricorrente e riconoscibile."@it ,
                           "Associates an Artwork with a recurrent and recognizable motif it exhibits."@en ;
              rdfs:label "ha motivo"@it ,
                         "has motif"@en .


###  https://w3id.org/vibe-ontology/hasOriginPeriod
vibe:hasOriginPeriod rdf:type owl:ObjectProperty ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:TimeInterval ;
                     rdfs:comment "Specifica l'intervallo temporale durante il quale un'Estetica è emersa per la prima volta."@it ,
                                  "Specifies the time interval during which an Aesthetic first emerged."@en ;
                     rdfs:label "ha periodo di origine"@it ,
                                "has origin period"@en .


###  https://w3id.org/vibe-ontology/hasPeriodDefinition
vibe:hasPeriodDefinition rdf:type owl:ObjectProperty ;
                         rdfs:domain owl:Thing ;
                         rdfs:range vibe:PeriodDefinition ;
                         rdfs:comment "Associa un'entità a una Definizione di periodo che la colloca in un contesto temporale."@it ,
                                      "Associates an entity with a PeriodDefinition that situates it within a temporal context."@en ;
                         rdfs:label "ha definizione di periodo"@it ,
                                    "has period definition"@en .


###  https://w3id.org/vibe-ontology/hasPlatform
vibe:hasPlatform rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf vibe:relatedTo ;
                 rdfs:domain vibe:Aesthetic ;
                 rdfs:range vibe:Platform ;
                 rdfs:comment "Associa un'Estetica a una Piattaforma su cui essa circola o è stata diffusa."@it ,
                              "Associates an Aesthetic with a Platform on which it circulates or has been disseminated."@en ;
                 rdfs:label "ha piattaforma"@it ,
                            "has platform"@en .


###  https://w3id.org/vibe-ontology/hasPrimaryPlatform
vibe:hasPrimaryPlatform rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf vibe:hasPlatform ;
                        rdfs:domain vibe:Aesthetic ;
                        rdfs:range vibe:Platform ;
                        rdfs:comment "Specifica la Piattaforma principale attraverso cui un'Estetica è prevalentemente diffusa o ha acquisito visibilità."@it ,
                                     "Specifies the main Platform through which an Aesthetic is primarily disseminated or has gained visibility."@en ;
                        rdfs:label "ha piattaforma principale"@it ,
                                   "has primary platform"@en .


###  https://w3id.org/vibe-ontology/hasRelatedBrand
vibe:hasRelatedBrand rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf vibe:relatedTo ;
                     rdfs:domain vibe:Aesthetic ;
                     rdfs:range vibe:Brand ;
                     rdfs:comment "Associa un'Estetica a un Brand che le è caratteristico o culturalmente affine."@it ,
                                  "Associates an Aesthetic with a Brand that is characteristic of or culturally aligned with it."@en ;
                     rdfs:label "ha brand associato"@it ,
                                "has related brand"@en .


###  https://w3id.org/vibe-ontology/hasRelatedWork
vibe:hasRelatedWork rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf vibe:relatedTo ;
                    rdfs:domain vibe:Aesthetic ;
                    rdfs:range vibe:Artwork ;
                    rdfs:comment "Associa un'Estetica a un'Opera considerata rappresentativa o tematicamente correlata."@it ,
                                 "Associates an Aesthetic with an Artwork considered representative of or thematically related to it."@en ;
                    rdfs:label "ha opera associata"@it ,
                               "has related work"@en .


###  https://w3id.org/vibe-ontology/hasSubgenre
vibe:hasSubgenre rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf vibe:relatedTo ;
                 owl:inverseOf vibe:isSubgenreOf ;
                 rdfs:domain vibe:Aesthetic ;
                 rdfs:range vibe:Aesthetic ;
                 rdfs:comment "Collega un'Estetica a un'Estetica più specifica che ne costituisce una sottovariante."@it ,
                              "Relates an Aesthetic to a more specific Aesthetic that constitutes one of its subvariants."@en ;
                 rdfs:label "ha sottogenere"@it ,
                            "has subgenre"@en .


###  https://w3id.org/vibe-ontology/hasTheme
vibe:hasTheme rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Artwork ;
              rdfs:range vibe:Theme ;
              rdfs:comment "Associa un'Opera a un Tema che esprime, veicola o mette in primo piano."@it ,
                           "Associates an Artwork with a Theme it conveys, expresses, or foregrounds."@en ;
              rdfs:label "ha tema"@it ,
                         "has theme"@en .


###  https://w3id.org/vibe-ontology/hasValue
vibe:hasValue rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:Aesthetic ;
              rdfs:range vibe:Value ;
              rdfs:comment "Associa un'Estetica a un Valore che ne caratterizza l'orientamento."@it ,
                           "Associates an Aesthetic with an abstract Value that characterizes its orientation."@en ;
              rdfs:label "ha valore"@it ,
                         "has value"@en .


###  https://w3id.org/vibe-ontology/influenced
vibe:influenced rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf vibe:relatedTo ;
                owl:inverseOf vibe:influencedBy ;
                rdfs:domain vibe:Aesthetic ;
                rdfs:range vibe:Aesthetic ;
                rdfs:comment "Collega un'Estetica a un'altra Estetica che essa ha influenzato in termini di stile, motivi o valori, o altro."@it ,
                             "Relates an Aesthetic to another Aesthetic that it has influenced in terms of style, motifs, values, or other."@en ;
                rdfs:label "ha influenzato"@it ,
                           "influenced"@en .


###  https://w3id.org/vibe-ontology/influencedBy
vibe:influencedBy rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf vibe:relatedTo ;
                  rdfs:domain vibe:Aesthetic ;
                  rdfs:range vibe:Aesthetic ;
                  rdfs:comment "Collega un'Estetica a un'altra Estetica da cui essa ha tratto influenza stilistica, tematica o culturale."@it ,
                               "Relates an Aesthetic to another Aesthetic from which it has drawn stylistic, thematic, or cultural influence."@en ;
                  rdfs:label "influenced by"@en ,
                             "influenzato da"@it .


###  https://w3id.org/vibe-ontology/isMemberOf
vibe:isMemberOf rdf:type owl:ObjectProperty ;
                rdfs:domain owl:Thing ;
                rdfs:range vibe:Collection ;
                rdfs:comment "Collega un'entità alla Collezione di cui è membro costituente."@it ,
                             "Relates an entity to the Collection of which it is a constituent member."@en ;
                rdfs:label "is member of"@en ,
                           "è membro di"@it .


###  https://w3id.org/vibe-ontology/isRoleInTimeOf
vibe:isRoleInTimeOf rdf:type owl:ObjectProperty ;
                    rdfs:domain vibe:TimeIndexedRole ;
                    rdfs:range vibe:Platform ;
                    rdfs:comment "Collega un TimeIndexedRole alla Piattaforma il cui ruolo temporalmente situato viene descritto."@it ,
                                 "Links a TimeIndexedRole to the Platform whose temporally situated role is being described."@en ;
                    rdfs:label "is role in time of"@en ,
                               "è ruolo nel tempo di"@it .


###  https://w3id.org/vibe-ontology/isSubgenreOf
vibe:isSubgenreOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf vibe:relatedTo ;
                  rdfs:domain vibe:Aesthetic ;
                  rdfs:range vibe:Aesthetic ;
                  rdfs:comment "Collega un'Estetica a un'Estetica più ampia di cui essa è una sottovariante più specifica."@it ,
                               "Relates an Aesthetic to a broader Aesthetic of which it is a more specific subvariant."@en ;
                  rdfs:label "is subgenre of"@en ,
                             "è sottogenere di"@it .


###  https://w3id.org/vibe-ontology/overlapsWith
vibe:overlapsWith rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf vibe:relatedTo ;
                  rdf:type owl:SymmetricProperty ;
                  rdfs:domain vibe:Aesthetic ;
                  rdfs:range vibe:Aesthetic ;
                  rdfs:comment "Indica che due Estetiche condividono elementi o associazioni significativi, senza che l'una sia sottogenere dell'altra. Questa proprietà è simmetrica."@it ,
                               "Indicates that two Aesthetics share significant elements or associations without either being a subgenre of the other. This property is symmetric."@en ;
                  rdfs:label "overlaps with"@en ,
                             "si sovrappone a"@it .


###  https://w3id.org/vibe-ontology/precedes
vibe:precedes rdf:type owl:ObjectProperty ,
                       owl:TransitiveProperty ;
              rdfs:domain vibe:Aesthetic ;
              rdfs:range vibe:Aesthetic ;
              rdfs:comment "Indica che un'Estetica precede temporalmente o stilisticamente un'altra. Questa proprietà è transitiva."@it ,
                           "Indicates that one Aesthetic temporally or stylistically precedes another. This property is transitive."@en ;
              rdfs:label "precede"@it ,
                         "precedes"@en .


###  https://w3id.org/vibe-ontology/relatedTo
vibe:relatedTo rdf:type owl:ObjectProperty ,
                        owl:SymmetricProperty ;
               rdfs:domain vibe:Aesthetic ;
               rdfs:range owl:Thing ;
               rdfs:comment "A general symmetric relation indicating that an Aesthetic is related to another entity in some culturally relevant way. Serves as a superproperty for more specific relation types."@en ,
                            "Una relazione simmetrica generale che indica che un'Estetica è correlata a un'altra entità in modo culturalmente rilevante. Funge da superpropietà per tipi di relazione più specifici."@it ;
               rdfs:label "associato a"@it ,
                          "related to"@en .


###  https://w3id.org/vibe-ontology/source
vibe:source rdf:type owl:ObjectProperty ;
            rdfs:domain vibe:PeriodDefinition ;
            rdfs:range vibe:Agent ;
            rdfs:comment "Indica l'Agente da cui una PeriodDefinition trae la propria evidenza o autorità."@it ,
                         "Indicates the Agent from which a PeriodDefinition derives its evidence or authority."@en ;
            rdfs:label "fonte"@it ,
                       "source"@en .


###  https://w3id.org/vibe-ontology/timeInterval
vibe:timeInterval rdf:type owl:ObjectProperty ;
                  rdfs:domain vibe:PeriodDefinition ;
                  rdfs:range vibe:TimeInterval ;
                  rdfs:comment "Collega una PeriodDefinition all'intervallo temporale che essa definisce."@it ,
                               "Links a PeriodDefinition to the TimeInterval it defines."@en ;
                  rdfs:label "intervallo temporale"@it ,
                             "time interval"@en .


###  https://w3id.org/vibe-ontology/withEntity
vibe:withEntity rdf:type owl:ObjectProperty ;
                rdfs:domain vibe:RepresentativeAssociation ;
                rdfs:range owl:Thing ;
                rdfs:comment "Collega una RepresentativeAssociation all'entità considerata rappresentativa dell'Estetica."@it ,
                             "Links a RepresentativeAssociation to the entity that is considered representative of the Aesthetic."@en ;
                rdfs:label "con entità"@it ,
                           "with entity"@en .


###  https://w3id.org/vibe-ontology/withRole
vibe:withRole rdf:type owl:ObjectProperty ;
              rdfs:domain vibe:TimeIndexedRole ;
              rdfs:range vibe:Role ;
              rdfs:comment "Specifica il Ruolo ricoperto dall'entità all'interno di una relazione di tipo Ruolo indicizzato temporalmente."@it ,
                           "Specifies the Role held by the entity within a TimeIndexedRole relation."@en ;
              rdfs:label "con ruolo"@it ,
                         "with role"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:DatatypeProperty ;
                                               owl:equivalentProperty vibe:alternateName .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:DatatypeProperty ;
                                                owl:equivalentProperty vibe:name .


###  https://w3id.org/vibe-ontology/URL
vibe:URL rdf:type owl:DatatypeProperty ;
         rdfs:domain vibe:Aesthetic ;
         rdfs:range xsd:anyURI ;
         rdfs:comment "The wiki URL (aesthetic)" ;
         rdfs:label "URL"@en ,
                    "URL"@it .


###  https://w3id.org/vibe-ontology/alternateName
vibe:alternateName rdf:type owl:DatatypeProperty ;
                   rdfs:domain vibe:Aesthetic ;
                   rdfs:range xsd:string ;
                   rdfs:label "alternate name"@en ,
                              "nome alternativo"@it .


###  https://w3id.org/vibe-ontology/approximateLabel
vibe:approximateLabel rdf:type owl:DatatypeProperty ;
                      rdfs:domain vibe:TimeInterval ;
                      rdfs:range xsd:string ;
                      rdfs:label "approximate label"@en ,
                                 "etichetta approssimativa"@it .


###  https://w3id.org/vibe-ontology/endYear
vibe:endYear rdf:type owl:DatatypeProperty ;
             rdfs:domain vibe:TimeInterval ;
             rdfs:range xsd:gYear ;
             rdfs:label "anno di fine"@it ,
                        "end year"@en .


###  https://w3id.org/vibe-ontology/name
vibe:name rdf:type owl:DatatypeProperty ;
          rdfs:domain vibe:Aesthetic ;
          rdfs:range xsd:string ;
          rdfs:label "name"@en ,
                     "nome"@it .


###  https://w3id.org/vibe-ontology/representativenessType
vibe:representativenessType rdf:type owl:DatatypeProperty ;
                            rdfs:domain vibe:RepresentativeAssociation ;
                            rdfs:range xsd:string ;
                            rdfs:label "representativeness type"@en ,
                                       "tipo di rappresentatività"@it .


###  https://w3id.org/vibe-ontology/startYear
vibe:startYear rdf:type owl:DatatypeProperty ;
               rdfs:domain vibe:TimeInterval ;
               rdfs:range xsd:gYear ;
               rdfs:label "anno di inizio"@it ,
                          "start year"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  https://w3id.org/vibe-ontology#Region
:Region rdf:type owl:Class ;
        rdfs:subClassOf vibe:Location ;
        rdfs:comment "A geographical area."@en ,
                     "Un'area geografica."@it ;
        rdfs:label "Region"@en ,
                   "Regione"@it .


###  https://w3id.org/vibe-ontology/Activity
vibe:Activity rdf:type owl:Class ;
              rdfs:comment "An action or practice carried out by individuals or groups, potentially associated with an aesthetic or subcultural context."@en ,
                           "Un’azione o pratica svolta da individui o gruppi, potenzialmente associata a un’estetica o a un contesto sottoculturale."@it ;
              rdfs:label "Activity"@en ,
                         "Attività"@it .


###  https://w3id.org/vibe-ontology/Aesthetic
vibe:Aesthetic rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty vibe:hasMember ;
                                 owl:minCardinality "1"^^xsd:nonNegativeInteger
                               ] ;
               rdfs:comment "A culturally emergent, open-ended category that groups a collection of heterogeneous elements (e.g., images, colors, objects, sounds, texts) perceived as coherently expressing a recognizable style, affect, or orientation. It is not defined by necessary and sufficient conditions, but by shared associations and family resemblances established by a community. E.g, the Frutiger Aero aesthetic groups glossy textures, bright gradients, nature imagery, and optimistic future cues into a recognizable early-2000s style."@en ,
                            "Una categoria culturalmente emergente e aperta che raggruppa una collezione di elementi eterogenei (ad esempio immagini, colori, oggetti, suoni, testi) percepiti come espressione coerente di uno stile, un’affettività o un orientamento riconoscibile. Non è definita da condizioni necessarie e sufficienti, ma da associazioni condivise e somiglianze di famiglia stabilite da una comunità. Ad esempio, l’estetica Frutiger Aero raggruppa texture lucide, gradienti brillanti, immagini della natura e richiami a un futuro ottimistico in uno stile riconoscibile dei primi anni 2000."@it ;
               rdfs:label "Aesthetic"@en ,
                          "Estetica"@it .


###  https://w3id.org/vibe-ontology/Agent
vibe:Agent rdf:type owl:Class ;
           rdfs:comment "An entity capable of acting, creating, or influencing cultural artifacts or aesthetics, including individuals and groups."@en ,
                        "Un’entità capace di agire, creare o influenzare artefatti culturali o estetiche, inclusi individui e gruppi."@it ;
           rdfs:label "Agent"@en ,
                      "Agente"@it .


###  https://w3id.org/vibe-ontology/Album
vibe:Album rdf:type owl:Class ;
           rdfs:subClassOf vibe:MusicWork ;
           rdfs:comment "A music work consisting of a collection of recorded tracks released as a single unit."@en ,
                        "Un’opera musicale composta da una raccolta di tracce pubblicate come un’unica unità."@it ;
           rdfs:label "Album"@en ,
                      "Album"@it .


###  https://w3id.org/vibe-ontology/Anime
vibe:Anime rdf:type owl:Class ;
           rdfs:subClassOf vibe:Artwork ;
           rdfs:comment "A form of animated artwork originating primarily from Japanese media contexts."@en ,
                        "Una forma di opera animata originaria principalmente del contesto mediatico giapponese."@it ;
           rdfs:label "Anime"@en ,
                      "Anime"@it .


###  https://w3id.org/vibe-ontology/ArchitecturalWork
vibe:ArchitecturalWork rdf:type owl:Class ;
                       rdfs:subClassOf vibe:Artwork ;
                       rdfs:comment "An artwork consisting of buildings or spatial structures designed within architectural practice."@en ,
                                    "Un’opera costituita da edifici o strutture progettate nell’ambito dell’architettura."@it ;
                       rdfs:label "Architectural Work"@en ,
                                  "Opera architettonica"@it .


###  https://w3id.org/vibe-ontology/ArtistRole
vibe:ArtistRole rdf:type owl:Class ;
                rdfs:subClassOf vibe:Role ;
                rdfs:comment "Un ruolo svolto da un agente come creatore o contributore alla produzione artistica."@it ,
                             "role played by an agent as a creator or contributor to artistic production."@en ;
                rdfs:label "Artist Role"@en ,
                           "Ruolo di artista"@it .


###  https://w3id.org/vibe-ontology/Artwork
vibe:Artwork rdf:type owl:Class ;
             rdfs:comment "A creative artifact produced within any expressive medium, including visual (images, paintings, sculpture, architecture, film, videogames), auditory (music), textual (literature), or embodied/industrial forms (fashion). It is treated as a generic work entity independent of medium-specific taxonomies."@en ,
                          "Un artefatto creativo prodotto in qualsiasi mezzo espressivo, inclusi visivo (immagini, dipinti, sculture, architetture, film, videogiochi), sonoro (musica), testuale (letteratura) o forme industriali come la moda. Viene trattato come un'opera indipendente dalle tassonomie relative ai media."@it ;
             rdfs:label "Artwork"@en ,
                        "Opera d'arte"@it .


###  https://w3id.org/vibe-ontology/Beauty
vibe:Beauty rdf:type owl:Class ;
            rdfs:comment "A domain of products, practices, and industries related to personal care, cosmetics, skincare, and bodily appearance, often associated with aesthetic expression and identity construction."@en ,
                         "Ambito che comprende prodotti, pratiche e industrie legate alla cura della persona, alla cosmetica, alla skincare e all’aspetto corporeo, spesso associato all’espressione estetica e alla costruzione dell’identità."@it ;
            rdfs:label "Beauty"@en ,
                       "Cura della persona"@it .


###  https://w3id.org/vibe-ontology/Brand
vibe:Brand rdf:type owl:Class ;
           rdfs:comment "An identifiable commercial or institutional entity characterized by a name, identity, and set of associated meanings, values, and design practices, which can produce or influence artifacts, styles, and aesthetic associations."@en ,
                        "Un'entità commerciale o istituzionale identificabile caratterizzata da un nome, un’identità e un set di significati, valori e pratiche di design associate, che possono produrre o influenzare artefatti, stili e associazioni estetiche."@it ;
           rdfs:label "Brand"@en ,
                      "Marchio"@it .


###  https://w3id.org/vibe-ontology/City
vibe:City rdf:type owl:Class ;
          rdfs:subClassOf vibe:Location ;
          rdfs:comment "An urban location characterised by dense population and structured infrastructure."@en ,
                       "Città"@it ,
                       "Una località urbana caratterizzata da popolazione densa e infrastruttura organizzata."@it ;
          rdfs:label "City"@en .


###  https://w3id.org/vibe-ontology/Collection
vibe:Collection rdf:type owl:Class ;
                rdfs:comment "A set of entities grouped together, either explicitly or implicitly, based on perceived coherence, curation, or shared associations. Collections function as the primary means through which an Aesthetic is expressed and recognized, without requiring fixed or exhaustive membership."@en ,
                             "Un insieme di entità raggruppate assieme, in modo esplicito o implicito, per coerenza percepita o associazioni condivise. Le collezioni costituiscono il mezzo primario tramite il quale le estetiche vengono espresse o riconosciute; non richiedono la fissità o l'esausività dei loro membri."@it ;
                rdfs:label "Collection"@en ,
                           "Collezione"@it .


###  https://w3id.org/vibe-ontology/Color
vibe:Color rdf:type owl:Class ;
           rdfs:comment "A visual attribute perceived through light, often contributing to aesthetic identity."@en ,
                        "Un attributo visivo percepito attraverso la luce, che contribuisce all’identità estetica."@it ;
           rdfs:label "Color"@en ,
                      "Colore"@it .


###  https://w3id.org/vibe-ontology/ColorPalette
vibe:ColorPalette rdf:type owl:Class ;
                  rdfs:comment "A structured set of colors associated through recurrent co-occurrence, design conventions, or perceptual harmony, often contributing to the visual identity of an aesthetic."@en ,
                               "Un insieme strutturato di colori associati per co-occorrenza o armonia visiva, che spesso contribuisce all’identità di un’estetica."@it ;
                  rdfs:label "Color Palette"@en ,
                             "Palette di colori"@it .


###  https://w3id.org/vibe-ontology/Country
vibe:Country rdf:type owl:Class ;
             rdfs:subClassOf vibe:Location ;
             rdfs:comment "A geopolitical location representing a nation or state."@en ,
                          "Una località geopolitica che rappresenta una nazione o uno stato."@it ;
             rdfs:label "Country"@en ,
                        "Paese"@it .


###  https://w3id.org/vibe-ontology/DigitalPlace
vibe:DigitalPlace rdf:type owl:Class ;
                  rdfs:subClassOf vibe:Location ;
                  rdfs:comment "A virtual environment where interactions, content creation, or community practices occur (e.g., forums, websites, social networks)."@en ,
                               "Un ambiente virtuale in cui avvengono interazioni, creazione di contenuti o pratiche comunitarie (per esempio, forum, siti web, social network)."@it ;
                  rdfs:label "Digital Place"@en ,
                             "Luogo digitale"@it .


###  https://w3id.org/vibe-ontology/Fashion
vibe:Fashion rdf:type owl:Class ;
             rdfs:comment "A domain of embodied and material expression involving clothing, styling, and adornment practices, through which cultural meanings, identities, and aesthetic orientations are communicated."@en ,
                          "Un ambito di espressione materiale che coinvolge abbigliamento e pratiche di stile, attraverso cui si comunicano significati culturali, identità e orientamenti estetici."@it ;
             rdfs:label "Fashion"@en ,
                        "Moda"@it .


###  https://w3id.org/vibe-ontology/Film
vibe:Film rdf:type owl:Class ;
          rdfs:subClassOf vibe:Artwork ;
          rdfs:comment "A moving-image artwork produced within cinematic media."@en ,
                       "Un’opera audiovisiva prodotta nel contesto cinematografico."@it ;
          rdfs:label "Film"@en ,
                     "Film"@it .


###  https://w3id.org/vibe-ontology/FoodItem
vibe:FoodItem rdf:type owl:Class ;
              rdfs:comment "An edible item that may carry aesthetic or cultural significance."@en ,
                           "Un alimento che può avere rilevanza estetica o culturale."@it ;
              rdfs:label "Alimento"@it ,
                         "Food Item"@en .


###  https://w3id.org/vibe-ontology/Group
vibe:Group rdf:type owl:Class ;
           rdfs:subClassOf vibe:Agent ;
           rdfs:comment "A collection of agents acting or identified as a unit."@en ,
                        "Un insieme di agenti che agiscono o sono identificati come un’unità."@it ;
           rdfs:label "Group"@en ,
                      "Gruppo"@it .


###  https://w3id.org/vibe-ontology/IconicFigure
vibe:IconicFigure rdf:type owl:Class ;
                  rdfs:subClassOf vibe:Role ;
                  rdfs:comment "A role representing an individual strongly associated with an aesthetic."@en ,
                               "Un ruolo che rappresenta un individuo fortemente associato a un’estetica."@it ;
                  rdfs:label "Figura iconica"@it ,
                             "Iconic Figure"@en .


###  https://w3id.org/vibe-ontology/Image
vibe:Image rdf:type owl:Class ;
           rdfs:subClassOf vibe:Artwork ;
           rdfs:comment "A visual artwork such as a photograph or digital image."@en ,
                        "Un’opera visiva come una fotografia o immagine digitale."@it ;
           rdfs:label "Image"@en ,
                      "Immagine"@it .


###  https://w3id.org/vibe-ontology/InteriorDesign
vibe:InteriorDesign rdf:type owl:Class ;
                    rdfs:subClassOf vibe:ArchitecturalWork ;
                    rdfs:comment "A form of architectural work focused on the design of interior spaces."@en ,
                                 "Una forma di progettazione architettonica focalizzata sugli spazi interni."@it ;
                    rdfs:label "Design d’interni"@it ,
                               "Interior Design"@en .


###  https://w3id.org/vibe-ontology/LiteraryWork
vibe:LiteraryWork rdf:type owl:Class ;
                  rdfs:subClassOf vibe:Artwork ;
                  rdfs:comment "A textual artwork such as a novel, poem, or written narrative."@en ,
                               "Un’opera testuale come romanzi, poesie o narrazioni scritte."@it ;
                  rdfs:label "Literary Work"@en ,
                             "Opera letteraria"@it .


###  https://w3id.org/vibe-ontology/Location
vibe:Location rdf:type owl:Class ;
              rdfs:comment "A spatial entity representing a physical or a digital place."@en ,
                           "Un’entità spaziale che rappresenta un luogo fisico o digitale."@it ;
              rdfs:label "Location"@en ,
                         "Luogo"@it .


###  https://w3id.org/vibe-ontology/Motif
vibe:Motif rdf:type owl:Class ;
           rdfs:comment "A recurrent and recognizable element (visual, conceptual, or stylistic) that contributes to the identity of an aesthetic through repeated association. E.g., the Frutiger Aero aesthetic's motifs include skeuomorphism, glossy textures, bubbles, nature imagery, and Frutiger-type fonts."@en ,
                        "Un elemento ricorrente e riconoscibile (di tipo visivo, concettuale o stilistico) che contribuisce all’identità di un’estetica attraverso associazioni ripetute. Per esempio, nell'estetica Frutiger Aero, i motivi includono scheumorfismo, texture lucide, scene di natura e font di tipo Frutiger."@it ;
           rdfs:label "Motif"@en ,
                      "Motivo"@it .


###  https://w3id.org/vibe-ontology/MusicWork
vibe:MusicWork rdf:type owl:Class ;
               rdfs:subClassOf vibe:Artwork ;
               rdfs:comment "An artwork expressed through sound and musical composition."@en ,
                            "Un’opera espressa attraverso il suono e la composizione musicale."@it ;
               rdfs:label "Music Work"@en ,
                          "Opera musicale"@it .


###  https://w3id.org/vibe-ontology/Painting
vibe:Painting rdf:type owl:Class ;
              rdfs:subClassOf vibe:Artwork ;
              rdfs:comment "A visual artwork created using paint on a surface."@en ,
                           "Un’opera visiva realizzata con pittura su una superficie."@it ;
              rdfs:label "Dipinto"@it ,
                         "Painting"@en .


###  https://w3id.org/vibe-ontology/PeriodDefinition
vibe:PeriodDefinition rdf:type owl:Class ;
                      rdfs:subClassOf [ rdf:type owl:Restriction ;
                                        owl:onProperty vibe:timeInterval ;
                                        owl:minCardinality "1"^^xsd:nonNegativeInteger
                                      ] ;
                      rdfs:comment "A temporally bounded but potentially imprecise interval used to situate entities or phenomena in time, allowing for vague or overlapping boundaries, in alignment with models such as PeriodO."@en ,
                                   "Un intervallo temporale delimitato ma potenzialmente impreciso usato per collocare entità o fenomeni nel tempo, che consente di definire confini vaghi o con sovrapposizioni, allineato a modellazioni come PeriodO."@it ;
                      rdfs:label "Definizione di periodo"@it ,
                                 "Period Definition"@en .


###  https://w3id.org/vibe-ontology/Person
vibe:Person rdf:type owl:Class ;
            rdfs:subClassOf vibe:Agent ;
            owl:disjointWith vibe:Platform ,
                             vibe:TimeInterval ;
            rdfs:comment "An individual human agent."@en ,
                         "Un individuo umano."@it ;
            rdfs:label "Person"@en ,
                       "Persona"@it .


###  https://w3id.org/vibe-ontology/Platform
vibe:Platform rdf:type owl:Class ;
              rdfs:comment "A socio-technical system that enables and constrains interaction, content production, and dissemination, while exerting agency through its design, governance, and algorithmic mechanisms, thereby shaping the emergence and visibility of aesthetics."@en ,
                           "Un sistema socio-tecnico che abilita e al tempo stesso vincola l’interazione, la produzione di contenuti e la loro diffusione, esercitando un’agenzia attraverso il proprio design, le forme di governance e i meccanismi algoritmici, e contribuendo così a modellare l’emergere e la visibilità delle estetiche."@it ;
              rdfs:label "Piattaforma"@it ,
                         "Platform"@en .


###  https://w3id.org/vibe-ontology/PrimaryRole
vibe:PrimaryRole rdf:type owl:Class ;
                 rdfs:subClassOf vibe:Role ;
                 rdfs:comment "A role indicating a primary or central association within a context."@en ,
                              "Un ruolo che indica un’associazione primaria o centrale in un contesto."@it ;
                 rdfs:label "Primary Role"@en ,
                            "Ruolo primario"@it .


###  https://w3id.org/vibe-ontology/RepresentativeAssociation
vibe:RepresentativeAssociation rdf:type owl:Class ;
                               rdfs:comment "A reified relation linking an Aesthetic to an entity that is considered representative of it. Such associations encode the mechanisms through which an aesthetic is recognized and constructed, and may be qualified by temporal scope, degree of representativeness, or role (e.g., primary)."@en ,
                                            "Una relazione reificata che collega un’Estetica a un’entità considerata rappresentativa di essa. Tali associazioni codificano i meccanismi attraverso cui un’estetica viene riconosciuta e costruita, e possono essere qualificate rispetto all’estensione temporale, al grado di rappresentatività o al ruolo (ad esempio, primario)."@it ;
                               rdfs:label "Associazione rappresentativa"@it ,
                                          "Representative Association"@en .


###  https://w3id.org/vibe-ontology/Role
vibe:Role rdf:type owl:Class ;
          rdfs:comment "A role is a context-dependent function or qualification assigned to an entity within a relation."@en ,
                       "Un ruolo è una funzione o qualificazione dipendente dal contesto assegnata a un’entità all’interno di una relazione."@it ;
          rdfs:label "Role"@en ,
                     "Ruolo"@it .


###  https://w3id.org/vibe-ontology/Song
vibe:Song rdf:type owl:Class ;
          rdfs:subClassOf vibe:MusicWork ;
          rdfs:comment "A single musical composition, typically consisting of lyrics and melody."@en ,
                       "Una composizione musicale singola, tipicamente composta da testo e melodia."@it ;
          rdfs:label "Canzone"@it ,
                     "Song"@en .


###  https://w3id.org/vibe-ontology/Subculture
vibe:Subculture rdf:type owl:Class ;
                rdfs:comment "A socially situated group or network characterized by shared practices, values, and symbolic systems that differentiate it from broader cultural contexts, often contributing to the emergence and stabilization of specific aesthetics."@en ,
                             "Un gruppo o una rete socialmente situata caratterizzata da pratiche, valori e sistemi simbolici condivisi che la distinguono dal contesto culturale più ampio, contribuendo spesso all’emergere e alla stabilizzazione di specifiche estetiche."@it ;
                rdfs:label "Sottocultura"@it ,
                           "Subculture"@en .


###  https://w3id.org/vibe-ontology/TVShow
vibe:TVShow rdf:type owl:Class ;
            rdfs:subClassOf vibe:Artwork ;
            rdfs:comment "A serial audiovisual work produced for television or streaming platforms."@en ,
                         "Un’opera audiovisiva seriale prodotta per televisione o piattaforme streaming."@it ;
            rdfs:label "Serie TV"@it ,
                       "TV Show"@en .


###  https://w3id.org/vibe-ontology/Theme
vibe:Theme rdf:type owl:Class ;
           rdfs:comment "An abstract conceptual orientation or narrative underlying an aesthetic, capturing its dominant meanings, affective tone, or worldview. E.g., the theme of the Frutiger Aero aesthetic can be described as an optimistic, clean, and nature-integrated vision of the near future."@en ,
                        "Un orientamento concettuale astratto o una struttura narrativa sottostante a un’estetica, che ne cattura i significati dominanti, il tono affettivo o la visione del mondo. Ad esempio, il tema dell'estetica Frutiger Aero può essere descritto come una visione ottimistica, pulita e integrata con la natura del futuro prossimo."@it ;
           rdfs:label "Tema"@it ,
                      "Theme"@en .


###  https://w3id.org/vibe-ontology/TimeIndexedRole
vibe:TimeIndexedRole rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty vibe:atTime ;
                                       owl:minCardinality "1"^^xsd:nonNegativeInteger
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty vibe:forAesthetic ;
                                       owl:minCardinality "1"^^xsd:nonNegativeInteger
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty vibe:withRole ;
                                       owl:minCardinality "1"^^xsd:nonNegativeInteger
                                     ] ;
                     rdfs:comment "A contextual role assigned to an entity within a relation that is explicitly bound to a temporal interval, allowing the same entity to hold different roles at different times."@en ,
                                  "Un ruolo assegnato a un’entità all’interno di una relazione, esplicitamente vincolato a un intervallo temporale, cosa che permette alla stessa entità di avere ruoli diversi in tempi diversi."@it ;
                     rdfs:label "Ruolo indicizzato temporalmente"@it ,
                                "Time Indexed Role"@en .


###  https://w3id.org/vibe-ontology/TimeInterval
vibe:TimeInterval rdf:type owl:Class ;
                  rdfs:comment "A temporal extent with a start and/or end that may be precisely defined or approximate, used to qualify the temporal validity of entities, roles, or associations."@en ,
                               "Un’estensione temporale con un inizio e/o una fine, che può essere precisa o approssimata, usata per qualificare la validità temporale di entità, ruoli o associazioni."@it ;
                  rdfs:label "Intervallo temporale"@it ,
                             "Time Interval"@en .


###  https://w3id.org/vibe-ontology/Value
vibe:Value rdf:type owl:Class ;
           rdfs:comment "An abstract principle, an affective/axiological orientation, or evaluative dimension (ethical, cultural, aesthetic, or ideological) associated with entities or aesthetics. Values are not limited to moral judgments but include broader attitudinal or conceptual stances. E.g., the aesthetic Frutiger Aero is associated with optimism, cleanliness, techno-natural harmony."@en ,
                        "Un principio astratto, un orientamento affettivo/assiologico o una dimensione valutativa (etica, culturale, estetica o ideologica) associata a entità o estetiche. I valori non si limitano ai giudizi morali, ma includono anche atteggiamenti e posizioni concettuali più ampie. Ad esempio, l’estetica Frutiger Aero è associata a ottimismo, pulizia e armonia tecno-naturale."@it ;
           rdfs:label "Valore"@it ,
                      "Value"@en .


###  https://w3id.org/vibe-ontology/Video
vibe:Video rdf:type owl:Class ;
           rdfs:subClassOf vibe:Artwork ;
           rdfs:comment "A moving-image artwork, typically digital."@en ,
                        "Un’opera audiovisiva, tipicamente digitale."@it ;
           rdfs:label "Video"@en ,
                      "Video"@it .


###  https://w3id.org/vibe-ontology/Videogame
vibe:Videogame rdf:type owl:Class ;
               rdfs:subClassOf vibe:Artwork ;
               rdfs:comment "An interactive digital artwork combining visual, narrative, and gameplay elements."@en ,
                            "Un’opera digitale interattiva che combina elementi visivi, narrativi e ludici."@it ;
               rdfs:label "Videogame"@en ,
                          "Videogioco"@it .


