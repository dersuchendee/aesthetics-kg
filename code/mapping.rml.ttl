    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/platform/{platform_slug}" ;
        rr:class ae-ont:Platform, ae-ont:DigitalPlace
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "platform" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "platform" ; rr:language "en" ]
    ] .

<#AestheticPlatformLinkMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_platforms.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:hasPrimaryPlatform ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/platform/{platform_slug}" ]
    ] .


