###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#MusicWork
:MusicWork rdf:type owl:Class ;
           rdfs:subClassOf :Artwork .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Painting
:Painting rdf:type owl:Class ;
          rdfs:subClassOf :Artwork .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#PeriodDefinition
:PeriodDefinition rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :timeInterval ;
                                    owl:minCardinality "1"^^xsd:nonNegativeInteger
                                  ] .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf :Agent ;
        owl:disjointWith :Platform ,
                         :TimeInterval .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Platform
:Platform rdf:type owl:Class .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#PrimaryRole
:PrimaryRole rdf:type owl:Class ;
             rdfs:subClassOf :Role .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#RepresentativeAssociation
:RepresentativeAssociation rdf:type owl:Class .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Role
:Role rdf:type owl:Class .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Subculture
:Subculture rdf:type owl:Class .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Theme
:Theme rdf:type owl:Class .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#TimeIndexedRole
:TimeIndexedRole rdf:type owl:Class ;
                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                   owl:onProperty :atTime ;
                                   owl:minCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :forAesthetic ;
                                   owl:minCardinality "1"^^xsd:nonNegativeInteger
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :withRole ;
                                   owl:minCardinality "1"^^xsd:nonNegativeInteger
                                 ] .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#TimeInterval
:TimeInterval rdf:type owl:Class .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Value
:Value rdf:type owl:Class ;
       rdfs:comment "Axiological/affective orientation cultivated by an aesthetic" .


###  http://www.semanticweb.org/annasofialippolis/ontologies/2026/3/vibeontologyproposal#Video
:Video rdf:type owl:Class ;
       rdfs:subClassOf :Artwork .


