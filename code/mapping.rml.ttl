###############################################################################
#  10. MOTIFS — via RepresentativeAssociation (motifDimension)
###############################################################################

<#MotifMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_motifs.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/motif/{motif_slug}" ;
        rr:class ae-ont:Motif
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "motif" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "motif" ; rr:language "en" ]
    ] .

<#MotifAssocMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_motifs.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/assoc/motif/{slug}-{motif_slug}" ;
        rr:class ae-ont:RepresentativeAssociation
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [
            rr:template "linking {name} to {motif} (motif)" ;
            rr:language "en"
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:comment ;
        rr:objectMap [
            rr:template "Representative association linking {name} to one of its key motifs: {motif}."@en ;
            rr:language "en"
        ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:forAesthetic ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:withEntity ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/motif/{motif_slug}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:associationDimension ;
        rr:objectMap [ rr:constant ae-ont:motifDimension ]
    ] .

<#AestheticMotifLinkMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_motifs.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/aesthetic/{slug}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate ae-ont:hasMember ;
        rr:objectMap [ rr:template "https://w3id.org/aesthetics-kg/resource/motif/{motif_slug}" ]
    ] .


###############################################################################
#  11. VALUES — via RepresentativeAssociation (valueDimension)
###############################################################################

<#ValueMap>
    rml:logicalSource [
        rml:source              "exploded/split/aesthetic_values.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "https://w3id.org/aesthetics-kg/resource/value/{value_slug}" ;
        rr:class ae-ont:Value
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rml:reference "value" ; rr:language "en" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rml:reference "value" ; rr:language "en" ]
    ] .

<#ValueAssocMap>
